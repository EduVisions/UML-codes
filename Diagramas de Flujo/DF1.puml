@startuml "Configurar institucion educativa"
skinparam SwimlaneTitleBackgroundColor #EEE
skinparam ActivityBackgroundColor #FFF9C4
skinparam ActivityBorderColor #7A1631
skinparam Arrow {
  Color #7A1631
}

|Administrador Institucional|
start
:Solicita configurar la institucion;

|Proceso de Negocio EduVerify|
:Recibe la solicitud;

|Administrador Institucional|
:Registra la informacion institucional;

|Proceso de Negocio EduVerify|
:Verifica que la informacion
este completa;

while (La informacion esta completa?) is (No)
  :Solicita correccion;

  |Administrador Institucional|
  :Registra la informacion institucional;

  |Proceso de Negocio EduVerify|
  :Verifica que la informacion
  este completa;
endwhile (Si)

|Administrador Institucional|
:Gestiona los usuarios institucionales;

if (Desea modificar usuarios institucionales?) then (Si)
  :Solicita modificar usuarios
  institucionales;

  |Proceso de Negocio EduVerify|
  :Modifica los usuarios institucionales;

  :Actualiza la gestion de usuarios
  institucionales;
else (No)
  |Proceso de Negocio EduVerify|
  :Finaliza la gestion de usuarios;
  stop
endif

|Administrador Institucional|
:Confirma la configuracion;

|Proceso de Negocio EduVerify|
:Registra la configuracion institucional;
stop
@enduml
