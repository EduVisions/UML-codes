@startuml "Crear examen supervisado"
skinparam SwimlaneTitleBackgroundColor #EEE
skinparam ActivityBackgroundColor #FFF9C4
skinparam ActivityBorderColor #7A1631
skinparam Arrow {
  Color #7A1631
}

|Docente|
start
:Solicita crear un examen
supervisado;

|Proceso de Negocio EduVerify|
:Recibe la solicitud y muestra
un formulario asistido;

|Docente|
:Proporciona la informacion
del examen;

|Proceso de Negocio EduVerify|
:Valida automaticamente datos,
fechas y condiciones de supervision;

while (Las condiciones son validas?) is (No)
  :Muestra observaciones y campos
  pendientes por corregir;

  |Docente|
  :Ajusta la informacion
  del examen;

  |Proceso de Negocio EduVerify|
  :Valida nuevamente datos,
  fechas y condiciones;
endwhile (Si)

|Docente|
:Define la programacion
del examen supervisado;

|Proceso de Negocio EduVerify|
:Verifica disponibilidad y conflictos
en la programacion;

if (La programacion esta disponible?) then (Si)
  :Configura parametros de supervision
  recomendados;
else (No)
  :Sugiere horarios alternativos;

  |Docente|
  :Ajusta la programacion
  del examen supervisado;

  |Proceso de Negocio EduVerify|
  :Configura parametros de supervision
  recomendados;
endif

|Docente|
:Confirma la creacion
del examen supervisado;

|Proceso de Negocio EduVerify|
:Programa el examen supervisado;

:Publica el examen y notifica
a los estudiantes inscritos;
stop
@enduml
