@startuml "Rendir examen supervisado"
skinparam SwimlaneTitleBackgroundColor #EEE
skinparam ActivityBackgroundColor #FFF9C4
skinparam ActivityBorderColor #7A1631
skinparam Arrow {
  Color #7A1631
}

|Estudiante|
start
:Inicia el proceso para rendir
el examen supervisado;

|Proceso de Negocio EduVerify|
:Valida la identidad del estudiante
mediante camara;

:Confirma el inicio de la evaluacion
supervisada;

:Habilita la evaluacion;

|Estudiante|
:Desarrolla las actividades
del examen;

|Proceso de Negocio EduVerify|
:Valida continuamente la identidad
mediante camara;

if (Registra algun comportamiento extrano?) then (Si)
  |Proceso de Negocio EduVerify|
  :Registra una incidencia
  de supervision;

  :Registra las evidencias
  asociadas a la incidencia;

  :Envia notificaciones
  por la incidencia;

  :Continua el seguimiento
  correspondiente;

  |Estudiante|
  :Continua respondiendo el examen
  bajo supervision;
else (No)
  |Estudiante|
  :Continua respondiendo el examen
  bajo supervision;
endif

|Estudiante|
:Finaliza el examen;

|Proceso de Negocio EduVerify|
:Registra la culminacion
de la evaluacion supervisada;
stop
@enduml
