@startuml "Reportes y Analisis"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

package "Reportes y Analisis" {
  class Report {
    - generatedDate
    - summary
    --
    + generateReport()
    + exportReport()
  }

  class StudentReport {
    - incidentCount
    - riskLevel
    --
    + calculateRiskLevel()
  }

  class Statistic {
    - name
    - value
    --
    + calculate()
  }

  class ExamTimeline {
    - generatedDate
    --
    + buildTimeline()
    + displayEvents()
  }
}

package "Shared Context" {
  class Teacher <<C>>
  class Student <<C>>
  class Exam <<C>>
  class Incident <<C>>
}

Teacher "1" -- "1..*" Report : generates
Report "1" *-- "1..*" StudentReport : contains
StudentReport "1" -- "1" Student : associated with
Report "1" *-- "1..*" Statistic : contains
ExamTimeline "1" -- "1" Exam : associated with
ExamTimeline "1" ..> "1..*" Incident : uses information from
Report ..> ExamTimeline : uses information from

@enduml
