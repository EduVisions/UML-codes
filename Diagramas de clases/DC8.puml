@startuml "Logging and Traceability"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

package "Logging and Traceability" {
  class AuditLog {
    - timestamp
    - action
    - description
    --
    + recordEvent()
    + viewHistory()
  }

  class AuditEvent {
    - eventType
    - occurrenceDate
    --
    + registerEvent()
  }

  class UserActivity {
    - activityDate
    - activityDescription
    --
    + registerActivity()
  }
}

package "Shared Context" {
  class User << (E,#2E7D32) >>
  class Exam << (E,#2E7D32) >>
  class Incident << (E,#2E7D32) >>
}

AuditLog "1" *-- "1..*" AuditEvent : contains
AuditLog "1" -- "1..*" UserActivity : records
User "1" -- "1..*" UserActivity : generates
UserActivity "1" -- "1" User : belongs to
AuditEvent "0..*" -- "0..1" Exam : associated with
AuditEvent "0..*" -- "0..1" Incident : associated with

@enduml
