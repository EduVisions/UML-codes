@startuml "CUS3 - Visualizar dashboard de supervision"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Docente" as Docente

rectangle "EduVerify" {
  usecase "Visualizar dashboard de supervision" as ucDashboard

  usecase "Consultar alertas activas" as ucAlertas
  usecase "Visualizar incidencias detectadas" as ucIncidencias
  usecase "Visualizar evidencia de incidencia" as ucEvidencia
  usecase "Consultar estado de examenes supervisados" as ucEstado
  usecase "Consultar actividad de estudiantes" as ucActividad
  usecase "Actualizar informacion del dashboard" as ucActualizar

  usecase "Gestionar alertas e incidencias" as ucGestionar
  usecase "Generar reporte de incidencias" as ucReporte
  usecase "Reportar plagio de estudiante" as ucPlagio
  usecase "Solicitar revision de incidencia" as ucRevision
  usecase "Filtrar incidencias por examen" as ucFiltrarExamen
  usecase "Filtrar incidencias por estudiante" as ucFiltrarEstudiante
}

Docente -- ucDashboard

ucDashboard -- ucAlertas : <<include>>
ucDashboard -- ucIncidencias : <<include>>
ucDashboard -- ucEvidencia : <<include>>
ucDashboard -- ucEstado : <<include>>
ucDashboard -- ucActividad : <<include>>
ucDashboard -- ucActualizar : <<include>>

ucDashboard -- ucGestionar : <<extend>>
ucDashboard -- ucReporte : <<extend>>
ucEvidencia -- ucPlagio : <<extend>>
ucIncidencias -- ucRevision : <<extend>>
ucIncidencias -- ucFiltrarExamen : <<extend>>
ucIncidencias -- ucFiltrarEstudiante : <<extend>>

@enduml
