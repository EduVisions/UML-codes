@startuml "CUS3 - Visualizar dashboard de supervision"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Docente" as Docente

rectangle "EduVerify" {
  usecase "Visualizar dashboard de supervision" as UC_Dashboard

  usecase "Consultar alertas activas" as UC_Alertas
  usecase "Visualizar incidencias detectadas" as UC_Incidencias
  usecase "Visualizar evidencia de incidencia" as UC_Evidencia
  usecase "Consultar estado de examenes supervisados" as UC_Estado
  usecase "Consultar actividad de estudiantes" as UC_Actividad
  usecase "Actualizar informacion del dashboard" as UC_Actualizar

  usecase "Gestionar alertas e incidencias" as UC_Gestionar
  usecase "Generar reporte de incidencias" as UC_Reporte
  usecase "Reportar plagio de estudiante" as UC_Plagio
  usecase "Solicitar revision de incidencia" as UC_Revision
  usecase "Filtrar incidencias por examen" as UC_FiltrarExamen
  usecase "Filtrar incidencias por estudiante" as UC_FiltrarEstudiante
}

Docente -- UC_Dashboard

UC_Dashboard -- UC_Alertas : <<include>>
UC_Dashboard -- UC_Incidencias : <<include>>
UC_Dashboard -- UC_Evidencia : <<include>>
UC_Dashboard -- UC_Estado : <<include>>
UC_Dashboard -- UC_Actividad : <<include>>
UC_Dashboard -- UC_Actualizar : <<include>>

UC_Dashboard -- UC_Gestionar : <<extend>>
UC_Dashboard -- UC_Reporte : <<extend>>
UC_Evidencia -- UC_Plagio : <<extend>>
UC_Incidencias -- UC_Revision : <<extend>>
UC_Incidencias -- UC_FiltrarExamen : <<extend>>
UC_Incidencias -- UC_FiltrarEstudiante : <<extend>>

@enduml
