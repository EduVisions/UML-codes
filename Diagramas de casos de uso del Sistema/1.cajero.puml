@startuml "Cajero Automático"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Cliente" as Cliente
actor "Administrator" as Admin
actor "Sistema Bancario" as Sistema

rectangle "Cajero Automático" {
  usecase "Sacar Dinero" as UC1
  usecase "Realizar Transferencias" as UC2
  usecase "Hacer Ingreso" as UC3
  usecase "Administrar Cajero" as UC4
}

Cliente -- UC1
Cliente -- UC2
Cliente -- UC3

UC1 -- Sistema
UC2 -- Sistema
UC3 -- Sistema

Admin -- UC4  

@enduml