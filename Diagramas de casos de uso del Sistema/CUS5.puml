@startuml "CUS5 - Consultar alertas e incidencias"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Estudiante" as Estudiante

rectangle "EduVerify" {
  usecase "Consultar alertas e incidencias" as ucConsultar

  usecase "Consultar historial de incidencias" as ucHistorial
  usecase "Visualizar detalle de incidencia" as ucDetalle
  usecase "Visualizar evidencia de incidencia" as ucEvidencia
  usecase "Consultar estado de incidencia" as ucEstado
  usecase "Consultar observaciones registradas" as ucObservaciones
  usecase "Reportar error de incidencia" as ucError

  usecase "Justificar incidencia detectada" as ucJustificar
  usecase "Solicitar revision manual de incidencia" as ucRevision
  usecase "Descargar evidencia de incidencia" as ucDescargar
  usecase "Filtrar incidencias por examen" as ucFiltrarExamen
  usecase "Filtrar incidencias por fecha" as ucFiltrarFecha
}

Estudiante -- ucConsultar

ucConsultar -- ucHistorial : <<include>>
ucConsultar -- ucDetalle : <<include>>
ucConsultar -- ucEvidencia : <<include>>
ucConsultar -- ucEstado : <<include>>
ucConsultar -- ucObservaciones : <<include>>
ucConsultar -- ucError : <<include>>

ucDetalle -- ucJustificar : <<extend>>
ucDetalle -- ucRevision : <<extend>>
ucEvidencia -- ucDescargar : <<extend>>
ucHistorial -- ucFiltrarExamen : <<extend>>
ucHistorial -- ucFiltrarFecha : <<extend>>

@enduml
