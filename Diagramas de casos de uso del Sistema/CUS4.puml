@startuml "CUS4 - Rendir examen supervisado"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Estudiante" as Estudiante

rectangle "EduVerify" {
  usecase "Rendir examen supervisado" as ucRendir

  usecase "Validar identidad del estudiante" as ucValidar
  usecase "Acceder al examen programado" as ucAcceder
  usecase "Visualizar instrucciones del examen" as ucInstrucciones
  usecase "Responder preguntas del examen" as ucResponder
  usecase "Monitorear identidad continuamente" as ucMonitorear
  usecase "Registrar evidencia multimedia" as ucEvidencia
  usecase "Registrar eventos de conectividad" as ucConectividad
  usecase "Entregar examen" as ucEntregar

  usecase "Detectar incidencia de supervision" as ucIncidencia
  usecase "Generar alerta de comportamiento sospechoso" as ucAlerta
  usecase "Registrar desconexion del estudiante" as ucDesconexion
  usecase "Registrar reconexion del estudiante" as ucReconexion
  usecase "Notificar incidencia al docente" as ucNotificar
  usecase "Bloquear acceso al examen" as ucBloquear
}

Estudiante -- ucRendir

ucRendir -- ucValidar : <<include>>
ucRendir -- ucAcceder : <<include>>
ucRendir -- ucInstrucciones : <<include>>
ucRendir -- ucResponder : <<include>>
ucRendir -- ucMonitorear : <<include>>
ucRendir -- ucEvidencia : <<include>>
ucRendir -- ucConectividad : <<include>>
ucRendir -- ucEntregar : <<include>>

ucMonitorear -- ucIncidencia : <<include>>
ucIncidencia -- ucAlerta : <<include>>
ucConectividad -- ucDesconexion : <<extend>>
ucConectividad -- ucReconexion : <<extend>>
ucIncidencia -- ucNotificar : <<extend>>
ucAcceder -- ucBloquear : <<extend>>

@enduml
