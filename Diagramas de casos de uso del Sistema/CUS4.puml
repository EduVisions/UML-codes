@startuml "CUS4 - Rendir examen supervisado"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Estudiante" as Estudiante

rectangle "EduVerify" {
  usecase "Rendir examen supervisado" as UC_Rendir

  usecase "Validar identidad del estudiante" as UC_Validar
  usecase "Acceder al examen programado" as UC_Acceder
  usecase "Visualizar instrucciones del examen" as UC_Instrucciones
  usecase "Responder preguntas del examen" as UC_Responder
  usecase "Monitorear identidad continuamente" as UC_Monitorear
  usecase "Registrar evidencia multimedia" as UC_Evidencia
  usecase "Registrar eventos de conectividad" as UC_Conectividad
  usecase "Entregar examen" as UC_Entregar

  usecase "Detectar incidencia de supervision" as UC_Incidencia
  usecase "Generar alerta de comportamiento sospechoso" as UC_Alerta
  usecase "Registrar desconexion del estudiante" as UC_Desconexion
  usecase "Registrar reconexion del estudiante" as UC_Reconexion
  usecase "Notificar incidencia al docente" as UC_Notificar
  usecase "Bloquear acceso al examen" as UC_Bloquear
}

Estudiante -- UC_Rendir

UC_Rendir -- UC_Validar : <<include>>
UC_Rendir -- UC_Acceder : <<include>>
UC_Rendir -- UC_Instrucciones : <<include>>
UC_Rendir -- UC_Responder : <<include>>
UC_Rendir -- UC_Monitorear : <<include>>
UC_Rendir -- UC_Evidencia : <<include>>
UC_Rendir -- UC_Conectividad : <<include>>
UC_Rendir -- UC_Entregar : <<include>>

UC_Monitorear -- UC_Incidencia : <<include>>
UC_Incidencia -- UC_Alerta : <<include>>
UC_Conectividad -- UC_Desconexion : <<extend>>
UC_Conectividad -- UC_Reconexion : <<extend>>
UC_Incidencia -- UC_Notificar : <<extend>>
UC_Acceder -- UC_Bloquear : <<extend>>

@enduml
