@startuml "CUS2 - Crear examen supervisado"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Docente" as Docente

rectangle "EduVerify" {
  usecase "Crear examen supervisado" as UC_Crear
  usecase "Definir informacion del examen" as UC_Info
  usecase "Programar examen" as UC_Programar
  usecase "Configurar reglas de supervision" as UC_Reglas
  usecase "Asignar estudiantes" as UC_Estudiantes
  usecase "Establecer criterios de evaluacion" as UC_Criterios
  usecase "Confirmar creacion del examen" as UC_Confirmar
  usecase "Cancelar creacion del examen" as UC_Cancelar
  usecase "Notificar examen programado" as UC_Notificar
}

Docente -- UC_Crear

UC_Crear -- UC_Info : <<include>>
UC_Crear -- UC_Programar : <<include>>
UC_Crear -- UC_Reglas : <<include>>
UC_Crear -- UC_Estudiantes : <<include>>
UC_Crear -- UC_Criterios : <<include>>
UC_Crear -- UC_Confirmar : <<include>>

UC_Crear -- UC_Cancelar : <<extend>>
UC_Confirmar -- UC_Notificar : <<extend>>

@enduml
