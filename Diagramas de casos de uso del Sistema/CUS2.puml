@startuml "CUS2 - Crear examen supervisado"
left to right direction
skinparam usecase {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam actor {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

actor "Docente" as Docente

rectangle "EduVerify" {
  usecase "Crear examen supervisado" as ucCrear
  usecase "Definir informacion del examen" as ucInfo
  usecase "Programar examen" as ucProgramar
  usecase "Configurar reglas de supervision" as ucReglas
  usecase "Asignar estudiantes" as ucEstudiantes
  usecase "Establecer criterios de evaluacion" as ucCriterios
  usecase "Confirmar creacion del examen" as ucConfirmar
  usecase "Cancelar creacion del examen" as ucCancelar
  usecase "Notificar examen programado" as ucNotificar
}

Docente -- ucCrear

ucCrear -- ucInfo : <<include>>
ucCrear -- ucProgramar : <<include>>
ucCrear -- ucReglas : <<include>>
ucCrear -- ucEstudiantes : <<include>>
ucCrear -- ucCriterios : <<include>>
ucCrear -- ucConfirmar : <<include>>

ucCrear -- ucCancelar : <<extend>>
ucConfirmar -- ucNotificar : <<extend>>

@enduml
