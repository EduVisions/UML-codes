@startuml "Query Alerts and Incidents"

actor "Student" as Student
boundary "Incident Interface" as UI
control "Incident Manager" as IncidentManager
control "Evidence Manager" as EvidenceManager
control "Report Manager" as ReportManager
entity "Incident" as Incident
entity "Evidence" as Evidence
entity "Incident History" as IncidentHistory
database "Incident Repository" as IncidentRepository
database "Evidence Repository" as EvidenceRepository
database "Incident History Repository" as IncidentHistoryRepository

Student -> UI : queryIncidents()
activate UI

UI -> IncidentManager : queryIncidents()
activate IncidentManager

IncidentManager -> IncidentRepository : getIncidentHistory(student)
activate IncidentRepository
IncidentRepository --> IncidentManager : incidentHistory
deactivate IncidentRepository

IncidentManager -> EvidenceManager : queryEvidence(incidentHistory)
activate EvidenceManager

EvidenceManager -> EvidenceRepository : getEvidence(incidentHistory)
activate EvidenceRepository
EvidenceRepository --> EvidenceManager : evidenceList
deactivate EvidenceRepository

EvidenceManager -> Evidence : organizeEvidence(evidenceList)
activate Evidence
Evidence --> EvidenceManager : organizedEvidence
deactivate Evidence

EvidenceManager --> IncidentManager : organizedEvidence
deactivate EvidenceManager

IncidentManager -> IncidentManager : consolidateInformation()
IncidentManager --> UI : consolidatedIncidents
deactivate IncidentManager

UI --> Student : showIncidents()

Student -> UI : selectIncident(incident)

UI -> IncidentManager : getIncidentDetail(incident)
activate IncidentManager

IncidentManager -> IncidentRepository : getIncidentDetail(incident)
activate IncidentRepository
IncidentRepository --> IncidentManager : incidentDetail
deactivate IncidentRepository

IncidentManager -> Incident : prepareDetail(incidentDetail)
activate Incident
Incident --> IncidentManager : detailPrepared
deactivate Incident

IncidentManager -> EvidenceManager : queryEvidence(incident)
activate EvidenceManager

EvidenceManager -> EvidenceRepository : getEvidence(incident)
activate EvidenceRepository
EvidenceRepository --> EvidenceManager : evidenceList
deactivate EvidenceRepository

EvidenceManager --> IncidentManager : evidenceList
deactivate EvidenceManager

IncidentManager --> UI : detailAndEvidence
deactivate IncidentManager

UI --> Student : showIncidentDetail()

alt Information correct
  Student -> UI : finishQuery()
  UI --> Student : queryFinished
else Error detected
  Student -> UI : reportIncidentError(reportData)

  UI -> ReportManager : registerErrorReport(reportData)
  activate ReportManager

  ReportManager -> IncidentHistory : registerEvent(reportData)
  activate IncidentHistory
  IncidentHistory --> ReportManager : eventRegistered
  deactivate IncidentHistory

  ReportManager -> IncidentHistoryRepository : storeReport(eventRegistered)
  activate IncidentHistoryRepository
  IncidentHistoryRepository --> ReportManager : reportRegistered
  deactivate IncidentHistoryRepository

  ReportManager --> UI : reportRegistered
  deactivate ReportManager

  UI --> Student : showConfirmation()
end

deactivate UI

@enduml
