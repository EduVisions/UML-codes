@startuml "Configure Educational Institution"

actor "Institutional Administrator" as Admin
boundary "Configuration Interface" as UI
control "Institutional Configuration Manager" as ConfigManager
control "User Manager" as UserManager
entity "Institution" as Institution
database "Configuration Repository" as ConfigurationRepository
database "User Repository" as UserRepository

Admin -> UI : accessConfigurationModule()
activate UI

UI -> ConfigManager : requestInstitutionalInformation()
activate ConfigManager

ConfigManager -> ConfigurationRepository : queryConfiguration()
activate ConfigurationRepository
ConfigurationRepository --> ConfigManager : institutionalInformation
deactivate ConfigurationRepository

ConfigManager --> UI : currentConfiguration
deactivate ConfigManager

UI --> Admin : showCurrentConfiguration()

Admin -> UI : updateInstitutionalInformation(data)

UI -> ConfigManager : saveInstitutionalChanges(data)
activate ConfigManager

ConfigManager -> Institution : validateInformation(data)
activate Institution
Institution --> ConfigManager : informationValidated
deactivate Institution

ConfigManager -> ConfigurationRepository : updateConfiguration(data)
activate ConfigurationRepository
deactivate ConfigurationRepository
deactivate ConfigManager

Admin -> UI : requestUserManagement()

UI -> UserManager : manageUsers(request)
activate UserManager

UserManager -> UserRepository : storeUserChanges(request)
activate UserRepository
deactivate UserRepository

UserManager --> UI : updateCompleted
deactivate UserManager

UI --> Admin : showSuccessMessage()
deactivate UI

@enduml
