@startuml "View Supervision Dashboard"

actor "Teacher" as Teacher
boundary "Supervision Dashboard" as Dashboard
control "Supervision Manager" as SupervisionManager
control "Incident Manager" as IncidentManager
control "Evidence Manager" as EvidenceManager
entity "Incident" as Incident
entity "Alert" as Alert
entity "Evidence" as Evidence
database "Incident Repository" as IncidentRepository
database "Alert Repository" as AlertRepository
database "Evidence Repository" as EvidenceRepository

Teacher -> Dashboard : accessDashboard()
activate Dashboard

Dashboard -> SupervisionManager : requestSupervisionInformation()
activate SupervisionManager

SupervisionManager -> IncidentManager : queryIncidents()
activate IncidentManager

IncidentManager -> IncidentRepository : getIncidents()
activate IncidentRepository
IncidentRepository --> IncidentManager : incidents
deactivate IncidentRepository

IncidentManager -> Incident : organizeIncidents(incidents)
activate Incident
Incident --> IncidentManager : organizedIncidents
deactivate Incident

IncidentManager --> SupervisionManager : organizedIncidents
deactivate IncidentManager

SupervisionManager -> IncidentManager : queryAlerts()
activate IncidentManager

IncidentManager -> AlertRepository : getAlerts()
activate AlertRepository
AlertRepository --> IncidentManager : alerts
deactivate AlertRepository

IncidentManager -> Alert : organizeAlerts(alerts)
activate Alert
Alert --> IncidentManager : organizedAlerts
deactivate Alert

IncidentManager --> SupervisionManager : organizedAlerts
deactivate IncidentManager

SupervisionManager -> SupervisionManager : consolidateInformation()
SupervisionManager --> Dashboard : consolidatedInformation
deactivate SupervisionManager

Dashboard --> Teacher : showDashboard()

Teacher -> Dashboard : selectIncident(incident)

Dashboard -> EvidenceManager : viewEvidence(incident)
activate EvidenceManager

EvidenceManager -> EvidenceRepository : getEvidence(incident)
activate EvidenceRepository
EvidenceRepository --> EvidenceManager : evidenceList
deactivate EvidenceRepository

EvidenceManager -> Evidence : prepareEvidence(evidenceList)
activate Evidence
Evidence --> EvidenceManager : evidencePrepared
deactivate Evidence

alt Evidence available
  EvidenceManager --> Dashboard : evidenceAvailable
  Dashboard --> Teacher : showEvidence()
else No associated evidence
  EvidenceManager --> Dashboard : evidenceNotAvailable
  Dashboard --> Teacher : showInformativeMessage()
end

deactivate EvidenceManager
deactivate Dashboard

@enduml
