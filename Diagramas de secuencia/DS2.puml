@startuml "Create Supervised Exam"

actor "Teacher" as Teacher
boundary "ExamInterface" as UI
control "ExamManager" as ExamManager
control "SupervisionManager" as SupervisionManager
control "SchedulingManager" as ScheduleManager
entity "Exam" as Exam
entity "SupervisionConfiguration" as SupervisionConfig
database "SupervisionConfigRepository" as SupervisionConfigRepository
database "ExamRepository" as ExamRepository

Teacher -> UI : accessExamModule()
activate UI

UI -> ExamManager : requestInitialData()
activate ExamManager

ExamManager -> SupervisionManager : queryAvailableConfigurations()
activate SupervisionManager

SupervisionManager -> SupervisionConfigRepository : getSupervisionConfigurations()
activate SupervisionConfigRepository
SupervisionConfigRepository --> SupervisionManager : availableConfigurations
deactivate SupervisionConfigRepository

SupervisionManager --> ExamManager : availableConfigurations
deactivate SupervisionManager

ExamManager --> UI : initialData
deactivate ExamManager

UI --> Teacher : showExamForm()

Teacher -> UI : createExam(data)

UI -> ExamManager : createExam(data)
activate ExamManager

ExamManager -> Exam : create(data)
activate Exam
Exam --> ExamManager : examCreated
deactivate Exam

ExamManager -> SupervisionManager : configureSupervision(parameters)
activate SupervisionManager

SupervisionManager -> SupervisionConfig : createConfiguration(parameters)
activate SupervisionConfig
SupervisionConfig --> SupervisionManager : configurationCreated
deactivate SupervisionConfig

SupervisionManager --> ExamManager : supervisionConfigured
deactivate SupervisionManager

ExamManager -> ScheduleManager : scheduleExam(dateTime)
activate ScheduleManager
ScheduleManager --> ExamManager : schedulingConfirmed
deactivate ScheduleManager

ExamManager -> ExamRepository : registerExam(exam)
activate ExamRepository
ExamRepository --> ExamManager : examRegistered
deactivate ExamRepository

ExamManager --> UI : creationSuccessful
deactivate ExamManager

UI --> Teacher : showConfirmation()
deactivate UI

@enduml
