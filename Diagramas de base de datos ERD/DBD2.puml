@startuml "Academic Management Database"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
skinparam linetype ortho

entity institutions {
    *id: BIGINT <<PK>>
    --
    *name: VARCHAR(150)
    *contact_email: VARCHAR(255)
    *created_at: DATETIME
    updated_at: DATETIME
}

entity courses {
    *id: BIGINT <<PK>>
    --
    *institution_id: BIGINT <<FK>>
    *name: VARCHAR(100)
    *code: VARCHAR(50)
    *created_at: DATETIME
    updated_at: DATETIME
}

entity exams {
    *id: BIGINT <<PK>>
    --
    *course_id: BIGINT <<FK>>
    *teacher_id: BIGINT
    *title: VARCHAR(150)
    *scheduled_date: DATETIME
    *duration_minutes: INT
    *supervision_rules: TEXT
    *created_at: DATETIME
    updated_at: DATETIME
}

institutions ||--o{ courses
courses ||--o{ exams
@enduml