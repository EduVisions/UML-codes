@startuml "Logging and Traceability Database"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
skinparam linetype ortho

entity audit_logs {
    *id: BIGINT <<PK>>
    --
    *timestamp: DATETIME
    *action: VARCHAR(100)
    *description: TEXT
    *created_at: DATETIME
}

entity audit_events {
    *id: BIGINT <<PK>>
    --
    *audit_log_id: BIGINT <<FK>>
    *event_type: VARCHAR(50)
    *occurrence_date: DATETIME
    exam_id: BIGINT
    incident_id: BIGINT
    *created_at: DATETIME
}

entity user_activities {
    *id: BIGINT <<PK>>
    --
    *audit_log_id: BIGINT <<FK>>
    *user_id: BIGINT
    *activity_date: DATETIME
    *activity_description: TEXT
    *created_at: DATETIME
}

audit_logs ||--o{ audit_events
audit_logs ||--o{ user_activities
@enduml
