@startuml "Incident Management Database"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
skinparam linetype ortho

entity incident_cases {
    *id: BIGINT <<PK>>
    --
    *incident_id: BIGINT
    *status: VARCHAR(50)
    *created_at: DATETIME
    resolved_at: DATETIME
    updated_at: DATETIME
}

entity justifications {
    *id: BIGINT <<PK>>
    --
    *incident_case_id: BIGINT <<FK>>
    *student_id: BIGINT
    *reason: TEXT
    *submitted_at: DATETIME
    *created_at: DATETIME
}

entity review_requests {
    *id: BIGINT <<PK>>
    --
    *incident_case_id: BIGINT <<FK>>
    *student_id: BIGINT
    *request_date: DATETIME
    *status: VARCHAR(50)
    *created_at: DATETIME
    updated_at: DATETIME
}

entity incident_history {
    *id: BIGINT <<PK>>
    --
    *incident_case_id: BIGINT <<FK>>
    *action: VARCHAR(100)
    *timestamp: DATETIME
    *performed_by: BIGINT
    *created_at: DATETIME
}

incident_cases ||--o{ justifications
incident_cases ||--o{ review_requests
incident_cases ||--o{ incident_history
@enduml
