@startuml "IAM Database"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
skinparam linetype ortho

entity users {
    *id: BIGINT <<PK>>
    --
    *email: VARCHAR(255)
    *password_hash: VARCHAR(255)
    *role: VARCHAR(50)
    *created_at: DATETIME
    *updated_at: DATETIME
}

entity students {
    *user_id: BIGINT <<PK, FK>>
    --
    *student_code: VARCHAR(50)
    *enrollment_date: DATE
    *created_at: DATETIME
    *updated_at: DATETIME
}

entity teachers {
    *user_id: BIGINT <<PK, FK>>
    --
    *hire_date: DATE
    *created_at: DATETIME
    *updated_at: DATETIME
}

users ||--o| students
users ||--o| teachers
@enduml