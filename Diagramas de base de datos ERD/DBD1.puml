@startuml classDiagram

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}

package "Shared Context" {
    class "UserId" {
        -value : UUID
    }
}

package "IAM Context" {
    entity "User" {
        -id : UserId
        --
        -email : String
        -passwordHash : String
        -role : String
        --
        +login()
        +logout()
    }

    entity "Student" {
        -userId : UserId
        --
        -studentCode : String
        -enrollmentDate : LocalDate
        --
        +verifyIdentity()
    }

    entity "Teacher" {
        -userId : UserId
        --
        -hireDate : LocalDate
        --
        +assignRole()
    }
}

User --> "1" UserId
Student --> "1" UserId
Teacher --> "1" UserId
@enduml