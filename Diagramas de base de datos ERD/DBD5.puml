@startuml "Reporting and Analytics Database"

skinparam class {
  BackgroundColor #FFF9C4
  BorderColor #7A1631
  StereotypeFontColor #2E7D32
}
skinparam Arrow {
  Color #7A1631
}
skinparam linetype ortho

entity reports {
    *id: BIGINT <<PK>>
    --
    *teacher_id: BIGINT
    *generated_date: DATETIME
    *summary: TEXT
    *created_at: DATETIME
}

entity student_reports {
    *id: BIGINT <<PK>>
    --
    *report_id: BIGINT <<FK>>
    *student_id: BIGINT
    *incident_count: INT
    *risk_level: VARCHAR(50)
    *created_at: DATETIME
}

entity statistics {
    *id: BIGINT <<PK>>
    --
    *report_id: BIGINT <<FK>>
    *name: VARCHAR(100)
    *value: DECIMAL(10,2)
    *created_at: DATETIME
}

entity exam_timelines {
    *id: BIGINT <<PK>>
    --
    *exam_id: BIGINT
    *generated_date: DATETIME
    *created_at: DATETIME
}

reports ||--o{ student_reports
reports ||--o{ statistics
@enduml
